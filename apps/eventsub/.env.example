# Twitch App (erstellen unter https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=dein_client_id
TWITCH_CLIENT_SECRET=dein_client_secret

# Dein Twitch Channel User ID oder Login-Name
# ID bekommst du via https://dev.twitch.tv/docs/api/reference#get-users
TWITCH_BROADCASTER_ID=12345678

# WebSocket Server URL (der OBS-Server)
WSS_SERVER_URL=ws://localhost:8080
