SERVER_HOST=127.0.0.1
PUBLIC_BASE_URL=https://127.0.0.1:3000

DASHBOARD_ORIGIN=http://127.0.0.1:5173
OVERLAY_ORIGIN=http://127.0.0.1:5174

LOG_LEVEL=info

# ============================================
# TWITCH API CONFIGURATION
# ============================================
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
TWITCH_BROADCASTER_ID=your_broadcaster_user_id
TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_PORT=3000
WS_PORT=8080
NODE_ENV=development

# ============================================
# DATABASE (Optional - für Analytics)
# ============================================
DATABASE_URL=postgresql://user:pass@localhost:5432/alerts

# ============================================
# STRIPE PAYMENTS (Trinkgeld)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# PAYPAL PAYMENTS (Trinkgeld)
# ============================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_MODE=sandbox  # sandbox | live

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this
API_KEY=your_internal_api_key_for_donation_webhooks
