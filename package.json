{
    "name": "hundekuchen-overlay-app",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm --parallel --filter @hundekuchen/server --filter @hundekuchen/dashboard --filter @hundekuchen/overlay dev",
        "dev:server": "pnpm --filter @hundekuchen/server dev",
        "dev:dashboard": "pnpm --filter @hundekuchen/dashboard dev",
        "dev:overlay": "pnpm --filter @hundekuchen/overlay dev",
        "typecheck": "pnpm -r typecheck",
        "build": "pnpm -r build"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
}